<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.helm.shquant.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/helm/Documents/Code/sh_quant/.venv/bin/python</string>
    <string>/Users/helm/Documents/Code/sh_quant/scripts/update_daily.py</string>
